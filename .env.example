# Server Configuration
PORT=5000
NODE_ENV=development
FRONTEND_URL=http://localhost:3000

# Database (PostgreSQL)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=ai_job_agent
DB_USER=postgres
DB_PASSWORD=your-postgres-password
DB_TEST_NAME=ai_job_agent-test

# JWT Secret (must be ≥32 chars and differ from refresh secret)
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production-min32chars
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=your-super-secret-refresh-key-change-this-in-production-diff
JWT_REFRESH_EXPIRES_IN=30d

# OpenAI API
OPENAI_API_KEY=your-openai-api-key
OPENAI_MODEL=gpt-4

# Redis (for BullMQ queues and caching)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ── Job Aggregation APIs ──────────────────────────────────────────────────────

# Adzuna (https://developer.adzuna.com/)
ADZUNA_APP_ID=your-adzuna-app-id
ADZUNA_API_KEY=your-adzuna-api-key

# JSearch/RapidAPI (https://rapidapi.com/letscrape-6bRBa3QguO5/api/jsearch)
RAPIDAPI_KEY=your-rapidapi-key
RAPIDAPI_HOST=jsearch.p.rapidapi.com

# USAJobs (https://developer.usajobs.gov/)
USAJOBS_API_KEY=your-usajobs-api-key

# RemoteOK (https://remoteok.com/api — free, key optional)
REMOTEOK_API_KEY=your-remoteok-api-key

# Greenhouse (https://developers.greenhouse.io/)
GREENHOUSE_API_KEY=your-greenhouse-api-key

# Wellfound (optional partner token)
WELLFOUND_API_TOKEN=

# ── Email Configuration ───────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-email-password
EMAIL_FROM=noreply@ai_job_agent.com

# ── File Upload ───────────────────────────────────────────────────────────────
MAX_FILE_SIZE=10485760
UPLOAD_PATH=./uploads

# ── AWS S3 ────────────────────────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_BUCKET_NAME=
AWS_REGION=us-east-1

# ── Cloudflare R2 (S3-compatible) ─────────────────────────────────────────────
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_PUBLIC_URL=  # Optional: custom domain e.g. https://files.yourdomain.com

# ── Google Cloud Storage (alternative) ───────────────────────────────────────
GOOGLE_CLOUD_PROJECT_ID=
GOOGLE_CLOUD_KEY_FILE=

# ── Azure Blob Storage (alternative) ─────────────────────────────────────────
AZURE_STORAGE_CONNECTION_STRING=
AZURE_STORAGE_CONTAINER_NAME=

# ── Rate Limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ── 2FA Settings ─────────────────────────────────────────────────────────────
TOTP_ISSUER=ai_job_agent

# ── Payment Gateway (Stripe) ─────────────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ── Video Interview ───────────────────────────────────────────────────────────
ZOOM_API_KEY=
ZOOM_API_SECRET=

# ── Analytics ─────────────────────────────────────────────────────────────────
GOOGLE_ANALYTICS_ID=

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=info

# ── Monitoring ────────────────────────────────────────────────────────────────
GRAFANA_PASSWORD=admin
